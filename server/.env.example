# Copy to server/.env for local dev (never commit the real .env).
# In production these are Cloud Run env vars / Secret Manager — see DEPLOY.md.

# Your Claude key — lives only here on the server, never in the frontend.
ANTHROPIC_API_KEY=sk-ant-...

# GitHub token for opening suggestion PRs (fine-grained PAT scoped to the repo:
# Contents read/write + Pull requests read/write). Never in the frontend.
GITHUB_TOKEN=github_pat_...
GITHUB_REPO=malkoromanievgenovich/human-first-canon
GITHUB_BASE=main
