# Copy to server/.env for local dev (never commit the real .env).
# In production these are Cloud Run env vars / Secret Manager — see DEPLOY.md.

# Your Claude key — lives only here on the server, never in the frontend.
ANTHROPIC_API_KEY=sk-ant-...

# Gmail that sends the feedback. GMAIL_APP_PASSWORD is a 16-char app password
# (Google Account → Security → 2-Step Verification → App passwords), NOT your login.
GMAIL_USER=roman.malko@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Where feedback lands (defaults to roman.malko@gmail.com).
FEEDBACK_TO=roman.malko@gmail.com
